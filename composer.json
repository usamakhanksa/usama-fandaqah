{
    "name": "fandaqah/hotel-dashboard",
    "type": "project",
    "description": "Hotel Dashboard",
    "require": {
        "php": "^8.2",
        "64robots/nova-fields": "^0.23.0",
        "alexbowers/nova-multiple-dashboard": "^1.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "laravel/framework": "^11.0",
        "laravel/nova": "*",
        "laravel/sanctum": "^4.0",
        "niklasravnsborg/laravel-pdf": "^4.1",
        "pktharindu/nova-permissions": "^3.1",
        "predis/predis": "^3.4",
        "spatie/laravel-activitylog": "^4.12",
        "watson/rememberable": "^7.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./laravelnova",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./nova-components/Calender"
        },
        {
            "type": "path",
            "url": "./nova-components/DashboardUnits"
        },
        {
            "type": "path",
            "url": "./nova-components/TelInput"
        },
        {
            "type": "path",
            "url": "./nova-components/Theme"
        },
        {
            "type": "path",
            "url": "./nova-components/Settings"
        },
        {
            "type": "path",
            "url": "./nova-components/TransactionsFeature"
        },
        {
            "type": "path",
            "url": "./nova-components/Units"
        },
        {
            "type": "path",
            "url": "./nova-components/TechincalSupport"
        },
        {
            "type": "path",
            "url": "./nova-components/FinancialManagement"
        },
        {
            "type": "path",
            "url": "./nova-components/Notification"
        },
        {
            "type": "path",
            "url": "./nova-components/NovaEditorV2"
        },
        {
            "type": "path",
            "url": "./nova-components/Percentage"
        },
        {
            "type": "path",
            "url": "./nova-components/Users"
        },
        {
            "type": "path",
            "url": "./nova-components/BigFilters"
        },
        {
            "type": "path",
            "url": "./nova-components/TotalOccupied"
        },
        {
            "type": "path",
            "url": "./nova-components/CustomerNotes"
        },
        {
            "type": "path",
            "url": "./nova-components/Pos"
        },
        {
            "type": "path",
            "url": "./nova-components/NotificationControl"
        },
        {
            "type": "path",
            "url": "./nova-components/CustomerReviews"
        },
        {
            "type": "path",
            "url": "./nova-components/ImagesCustomField"
        },
        {
            "type": "path",
            "url": "./nova-components/CustomToggle"
        },
        {
            "type": "path",
            "url": "./nova-components/CustomDate"
        },
        {
            "type": "path",
            "url": "./nova-components/Customers"
        },
        {
            "type": "path",
            "url": "./nova-components/UnitPrice"
        },
        {
            "type": "path",
            "url": "./packages/fandaqah/queuehealthchecker"
        },
        {
            "type": "path",
            "url": "./packages/php-mqtt/client"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php",
            "stubs/SparkStubs.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
