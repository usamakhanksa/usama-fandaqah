[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/filamentphp/notifications.git
	fetch = +refs/heads/*:refs/remotes/origin/*
	pushurl = git@github.com:filamentphp/notifications.git
[branch "5.x"]
	remote = origin
	merge = refs/heads/5.x
[remote "composer"]
	url = https://github.com/filamentphp/notifications.git
	fetch = +refs/heads/*:refs/remotes/composer/*
