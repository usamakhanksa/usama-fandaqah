[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/doctrine/dbal.git
	fetch = +refs/heads/*:refs/remotes/origin/*
	pushurl = git@github.com:doctrine/dbal.git
[branch "4.4.x"]
	remote = origin
	merge = refs/heads/4.4.x
[remote "composer"]
	url = https://github.com/doctrine/dbal.git
	fetch = +refs/heads/*:refs/remotes/composer/*
